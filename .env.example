# PostgreSQL
DATABASE_URL=postgresql+asyncpg://admin:securepassword@localhost:5432/crime_intelligence_db
DATABASE_URL_SYNC=postgresql://admin:securepassword@localhost:5432/crime_intelligence_db
DATABASE_NAME=crime_intelligence_db
DATABASE_USER=admin
DATABASE_PASSWORD=securepassword
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Neo4j (optional — app falls back gracefully if offline)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jsecurepassword

# Redis (optional — app falls back gracefully if offline)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redissecurepassword

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
# Provide one or more API keys separated by commas for round-robin load balancing
GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-1.5-pro

# JWT — change this to a random 64-char string in production
# Run `python -c "import secrets; print(secrets.token_hex(64))"` to generate one
JWT_SECRET_KEY=change_this_to_a_very_long_random_secret_in_production_64chars

# Server
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
EVIDENCE_UPLOAD_DIR=/app/uploads

# Frontend Vite URLs
FRONTEND_VITE_API_URL=/api
# The WebSocket URL must be absolute. Use wss:// for production HTTPS deployments.
FRONTEND_VITE_WS_URL=ws://localhost:8000/api/alerts/ws
